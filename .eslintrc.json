{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["airbnb-base"],
  "rules": {
  "no-console": "off",
  "no-unused-vars": "warn",
  "import/prefer-default-export": "off",
  "linebreak-style": "off",
  "no-multiple-empty-lines": ["error", { "max": 1 }],
  "class-methods-use-this": "off",
  "import/first": "off",
  "no-param-reassign": "off"
  }
}
